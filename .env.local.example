# Скопіюйте цей файл із назвою .env.local і впишіть значення
# зі свого проєкту Supabase: Project Settings -> API Keys
#
# Це ПУБЛІЧНІ ключі (вони і так видні кожному відвідувачу сайту).
# Секретний service_role ключ сюди НЕ вписуйте ніколи.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
